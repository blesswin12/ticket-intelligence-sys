{
  "name": "ticketdashboard",
  "version": "0.0.1",
  "private": true,
  "description": "A Fiori application for the Ticket Intelligence System",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "scripts": {
    "build": "ui5 build preload --clean-dest",
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo",
    "start": "ui5 serve",
    "start-local": "ui5 serve --config ui5-local.yaml"
  },
  "devDependencies": {
    "@sap/ux-ui5-tooling": "^1",
    "@ui5/cli": "^3",
    "ui5-task-zipper": "^3.6.0"
  }
}
